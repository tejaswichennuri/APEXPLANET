<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Tejaswi Chennuri | Portfolio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
    * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', 'Segoe UI', sans-serif;
  background: #f8fafc;
  color: #334155;
  line-height: 1.6;
}

/* NAVBAR */
nav {
  background: #0f172a;
  padding: 16px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  color: #6366f1;
  font-weight: 600;
  padding-left: 50px;
}

nav ul {
  display: flex;
  list-style: none;
}

nav ul li {
  margin-left: 24px;
}

nav ul li a {
  color: #e5e7eb;
  text-decoration: none;
  font-size: 15px;
}

nav ul li a:hover {
  color: #6366f1;
}

/* HERO */
.hero {
  min-height: 90vh;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60px;
  color: #f8fafc;
}

.hero h1 {
  font-size: 46px;
  font-weight: 600;
}

.hero h3 {
  color: #c7d2fe;
  margin: 10px 0;
}

.hero p {
  max-width: 500px;
  color: #cbd5f5;
}

.profile-img {
  width: 240px;
  border-radius: 50%;
  border: 4px solid #6366f1;
}
/* SOCIAL ICONS – IMPROVED VISIBILITY */
.socials {
  text-align: center;
  margin-top: 30px;
}

.socials a {
  font-size: 34px;              /* Increased size */
  margin: 0 14px;
  color:white;               /* Visible blue for light mode */
  transition: transform 0.3s, color 0.3s;
}

/* Hover effect */
.socials a:hover {
  transform: translateY(-4px);
  color:white;
  size: 30px;
}

/* DARK MODE FIX */
body.dark .socials a {
  color: #e5e7eb;               /* Light color for dark bg */
}

body.dark .socials a:hover {
  color: white;               /* Soft accent on hover */
}

/* BUTTON */
.btn {
  display: inline-block;
  margin-top: 22px;
  padding: 12px 26px;
  background: #2563eb;
  color: white;
  text-decoration: none;
  border-radius: 6px;
  font-size: 14px;
  transition: background 0.3s;
}

.btn:hover {
  background: #1d4ed8;
}

/* SECTIONS */
.section {
  padding: 90px 140px;
}

.section h2 {
  text-align: center;
  margin-bottom: 50px;
  font-size: 28px;
  color: #0f172a;
}

/* LIGHT / DARK */
.light {
  background: #f8fafc;
}

.dark {
  background: #f1f5f9;
}


/* EXPERIENCE & LEARNING – BLUE BACKGROUND */

 /* EXPERIENCE SECTION BACKGROUND */
.experience-bg {
  background-color: #f1f5f9;   /* Soft professional light */
  padding: 80px 20px;
}

/* Timeline cards */
.timeline {
  max-width: 900px;
  margin: 40px auto 0;
}

.timeline-item {
  background: #ffffff;
  padding: 20px 25px;
  margin-bottom: 20px;
  border-radius: 12px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

/* Dark mode support */
body.dark .experience-bg {
  background-color: #0f172a;   /* Dark slate */
}

body.dark .timeline-item {
  background: #1e293b;
  color: #e5e7eb;
}


/* SKILLS */
.skills-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
}

.skills-container span {
  background: #e0e7ff;
  color: #1e3a8a;
  padding: 8px 18px;
  border-radius: 20px;
  font-size: 14px;
}

/* PROJECTS */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 28px;
}

.project-card {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(15,23,42,0.08);
  transition: transform 0.3s;
}

.project-card:hover {
  transform: translateY(-6px);
}

.project-card img {
  width: 100%;
}

.project-card h3 {
  padding: 12px 18px 0;
  color: #0f172a;
}

.project-card p {
  padding: 6px 18px 14px;
  font-size: 14px;
}

.project-card a {
  padding: 0 18px 18px;
  display: inline-block;
  color: #2563eb;
  font-weight: 500;
}

/* CERTIFICATES */
.cert-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
  gap: 20px;
  
}

.cert-grid img {
  width: 75%;
  max-width: 60px;
  padding: 10px;
  background: #fff;
  border-radius: 12px;
}

/* CONTACT */
form {
  max-width: 480px;
  margin: auto;
}

form input,
form textarea {
  width: 100%;
  padding: 12px;
  margin: 10px 0;
  border-radius: 6px;
  border: 1px solid #cbd5e1;
}



/* FOOTER */
footer {
  background: #0f172a;
  color: #cbd5e1;
  text-align: center;
  padding: 22px;
  font-size: 14px;
}

/* DARK MODE */
body.dark {
  background: #020617;
  color: #e5e7eb;
}

body.dark .light {
  background: #020617;
}

body.dark .dark {
  background: #020617;
}

/* SCROLL ANIMATION */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: 1s ease;
}

.reveal.active {
  opacity: 1;
  transform: translateY(0);
}

/* BACK TO TOP */
#topBtn {
  position: fixed;
  bottom: 20px;
  left: 20px;
  display: none;
  background: #2563eb;
  color: white;
  border: none;
  padding: 10px 14px;
  border-radius: 50%;
  cursor: pointer;
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .hero {
    flex-direction: column;
    text-align: center;
  }

  .section {
    padding: 60px 30px;
  }
}
</style>
    
</head>
